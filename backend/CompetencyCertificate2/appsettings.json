{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DevConnection": "Server=localhost;Database=odooDb;Trusted_Connection=True;MultipleActiveResultSets=True;Encrypt=True;TrustServerCertificate=True;"
  },
  "AppSettings": {
    "JWTSecret": "local-development-only-secret-key-at-least-32-chars-long",
    "JWTIssuer": "CompetencyCertificate",
    "JWTAudience": "Competency_CertificateGen",
    "TokenExpiryMinutes": 30
  }
}
